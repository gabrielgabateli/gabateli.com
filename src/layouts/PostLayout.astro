---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import ProgressBar from '../components/ProgressBar.astro';
import BackToTop from '../components/BackToTop.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  tag: string;
  readTime?: string;
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}
const { title, description, date, tag, readTime = '5 min read', prevPost, nextPost } = Astro.props;
---

<BaseLayout title={title} description={description} hideAsciiBackground>
  <ProgressBar />
  <Nav />
  <main class="pb-20">
    <div class="mb-9">
      <a href="/blog" class="font-mono text-[12px] text-tertiary hover:text-secondary transition-colors">
        ← blog
      </a>
    </div>

    <article>
      <header class="mb-9 pb-6 border-b border-border">
        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[11px] text-quaternary">{date}</span>
          <span class="text-border">·</span>
          <span class="font-mono text-[11px] text-quaternary">{tag}</span>
          <span class="text-border">·</span>
          <span class="font-mono text-[11px] text-quaternary">{readTime}</span>
        </div>
        <h1 class="text-[22px] font-medium tracking-tight leading-[1.3] mb-2.5">{title}</h1>
        <p class="text-[14px] text-secondary leading-relaxed">{description}</p>
      </header>

      <div class="prose-custom">
        <slot />
      </div>
    </article>

    <footer class="mt-12 pt-6 border-t border-border">
      <div class="flex items-center justify-between">
        <a href="/blog" class="font-mono text-[12px] text-tertiary hover:text-secondary transition-colors">
          ← todos os posts
        </a>
        <div class="flex gap-2 sm:gap-4">
          {prevPost && (
            <a href={`/blog/${prevPost.slug}`} class="font-mono text-[12px] text-tertiary hover:text-secondary transition-colors">
              ← {prevPost.title.length > 22 ? prevPost.title.slice(0, 22) + '…' : prevPost.title}
            </a>
          )}
          {nextPost && (
            <a href={`/blog/${nextPost.slug}`} class="font-mono text-[12px] text-tertiary hover:text-secondary transition-colors">
              {nextPost.title.length > 22 ? nextPost.title.slice(0, 22) + '…' : nextPost.title} →
            </a>
          )}
        </div>
      </div>
    </footer>
  </main>
  <BackToTop />
</BaseLayout>