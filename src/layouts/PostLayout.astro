---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  tag: string;
  readTime?: string;
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}
const { title, description, date, tag, readTime = '5 min read', prevPost, nextPost } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="pb-20">
    <div class="mb-9">
      <a href="/blog" class="font-mono text-[12px] text-[#888] dark:text-[#555] hover:text-[#444] dark:hover:text-[#aaa] transition-colors">
        ← blog
      </a>
    </div>

    <article>
      <header class="mb-9 pb-6 border-b border-[#ebebeb] dark:border-[#1e1e1e]">
        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[11px] text-[#aaa] dark:text-[#555]">{date}</span>
          <span class="text-[#ddd] dark:text-[#333]">·</span>
          <span class="font-mono text-[11px] text-[#aaa] dark:text-[#555]">{tag}</span>
          <span class="text-[#ddd] dark:text-[#333]">·</span>
          <span class="font-mono text-[11px] text-[#aaa] dark:text-[#555]">{readTime}</span>
        </div>
        <h1 class="text-[22px] font-medium tracking-tight leading-[1.3] mb-2.5">{title}</h1>
        <p class="text-[14px] text-[#777] dark:text-[#555] leading-relaxed">{description}</p>
      </header>

      <div class="prose-custom">
        <slot />
      </div>
    </article>

    <footer class="mt-12 pt-6 border-t border-[#ebebeb] dark:border-[#1e1e1e]">
      <div class="flex items-center justify-between">
        <a href="/blog" class="font-mono text-[12px] text-[#888] dark:text-[#555] hover:text-[#444] dark:hover:text-[#aaa] transition-colors">
          ← todos os posts
        </a>
        <div class="flex gap-4">
          {prevPost && (
            <a href={`/blog/${prevPost.slug}`} class="font-mono text-[12px] text-[#888] dark:text-[#555] hover:text-[#444] dark:hover:text-[#aaa] transition-colors">
              ← {prevPost.title.length > 22 ? prevPost.title.slice(0, 22) + '…' : prevPost.title}
            </a>
          )}
          {nextPost && (
            <a href={`/blog/${nextPost.slug}`} class="font-mono text-[12px] text-[#888] dark:text-[#555] hover:text-[#444] dark:hover:text-[#aaa] transition-colors">
              {nextPost.title.length > 22 ? nextPost.title.slice(0, 22) + '…' : nextPost.title} →
            </a>
          )}
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>