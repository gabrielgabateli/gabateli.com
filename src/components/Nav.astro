---
import ThemeToggle from './ThemeToggle.astro';
const path = Astro.url.pathname;
---

<nav class="flex items-center justify-between py-10">
  <a href="/" class="text-[14px] sm:text-[15px] font-medium tracking-tight hover:opacity-70 transition-opacity">
    gabriel gabateli
  </a>
  <div class="flex items-center gap-3 sm:gap-7">
    <a
      href="/blog"
      class:list={[
        'text-[13px] sm:text-[14px] transition-colors',
        path.startsWith('/blog')
          ? 'text-fg font-medium'
          : 'text-tertiary hover:text-fg',
      ]}
    >blog</a>
    <a
      href="/tags"
      class:list={[
        'text-[13px] sm:text-[14px] transition-colors',
        path.startsWith('/tags')
          ? 'text-fg font-medium'
          : 'text-tertiary hover:text-fg',
      ]}
    >tags</a>
    <a
      href="/#projects"
      class="text-[13px] sm:text-[14px] text-tertiary hover:text-fg transition-colors"
      aria-label="projetos"
    >projects</a>
    <a
      href="/cv"
      class="text-[13px] sm:text-[14px] text-tertiary hover:text-fg transition-colors"
      aria-label="currículo"
    >cv</a>
    <ThemeToggle />
  </div>
</nav>