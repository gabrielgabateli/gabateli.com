<canvas
  id="ascii-background"
  aria-hidden="true"
  class="fixed inset-0 z-0 opacity-80 pointer-events-none select-none"
  style="width: 100vw; height: 100vh;"
></canvas>

<script is:inline data-astro-rerun>
(function () {
  // Avoid attaching global listeners more than once across view transitions.
  if (window.__asciiBgReady) return;
  window.__asciiBgReady = true;

  const CHARS = ['·', ':', '•', '-', '~', '∿', '+', '*'];
  const FONT_SIZE = 13;
  const DESKTOP_GAP = 26;
  const MOBILE_GAP = 34;
  const COLOR_VAR = '--color-secondary';
  const MIN_ALPHA = 0.05;
  const MAX_ALPHA = 0.22;
  const CURSOR_COLOR = '#ef4444';
  const CURSOR_RADIUS = 220;
  const CURSOR_ALPHA_BOOST = 0.30;
  const CURSOR_FOLLOW = 0.18;

  let rafId = null;
  let canvas = null;
  let ctx = null;
  let resizeTimeout = null;
  let lastFrame = 0;
  let isPaused = false;
  let cols = 0;
  let rows = 0;
  let gap = DESKTOP_GAP;
  let startTime = performance.now();
  let reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let mouseX = 0;
  let mouseY = 0;
  let targetMouseX = 0;
  let targetMouseY = 0;
  let mouseActive = false;
  const supportsPointerInteraction = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  function mapRange(value, inMin, inMax, outMin, outMax) {
    return ((value - inMin) * (outMax - outMin)) / (inMax - inMin) + outMin;
  }

  function clamp(value, min, max) {
    return Math.min(Math.max(value, min), max);
  }

  function updateCursorPosition(x, y) {
    if (!supportsPointerInteraction) return;
    targetMouseX = x;
    targetMouseY = y;
    if (!mouseActive) {
      mouseX = x;
      mouseY = y;
    }
    mouseActive = true;
  }

  function onPointerMove(event) {
    updateCursorPosition(event.clientX, event.clientY);
  }

  function onPointerLeave() {
    mouseActive = false;
  }

  function getFillColor() {
    const raw = getComputedStyle(document.documentElement).getPropertyValue(COLOR_VAR).trim();
    return raw || (document.documentElement.classList.contains('dark') ? '#aaa' : '#555');
  }

  function cleanup() {
    if (rafId) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
    isPaused = true;
  }

  function setupCanvas() {
    if (!canvas || !ctx || !canvas.isConnected) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    const width = rect.width;
    const height = rect.height;

    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);

    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.font = `${FONT_SIZE}px Geist Mono, monospace`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    gap = width < 768 ? MOBILE_GAP : DESKTOP_GAP;
    cols = Math.ceil(width / gap) + 1;
    rows = Math.ceil(height / gap) + 1;
  }

  function draw() {
    if (!canvas || !ctx || !canvas.isConnected) return;

    const rect = canvas.getBoundingClientRect();
    const width = rect.width;
    const height = rect.height;
    const centerX = width / 2;
    const centerY = height / 2;
    const now = performance.now();
    // Slow, ambient time scale.
    const t = (now - startTime) * 0.0004;
    const baseColor = getFillColor();

    // Smooth cursor follow for an organic aura feel.
    if (mouseActive) {
      mouseX += (targetMouseX - mouseX) * CURSOR_FOLLOW;
      mouseY += (targetMouseY - mouseY) * CURSOR_FOLLOW;
    }

    const radiusSq = CURSOR_RADIUS * CURSOR_RADIUS;

    ctx.clearRect(0, 0, width, height);

    for (let gy = 0; gy < rows; gy++) {
      for (let gx = 0; gx < cols; gx++) {
        const x = gx * gap;
        const y = gy * gap;
        const dx = x - centerX;
        const dy = y - centerY;
        const dist = Math.sqrt(dx * dx + dy * dy);

        // Layered sine waves: diagonal flow + circular ripple.
        const waveA = Math.sin(x * 0.014 + t * 1.0);
        const waveB = Math.sin(y * 0.012 - t * 0.7);
        const radial = Math.sin(dist * 0.012 - t * 1.3);

        let intensity = (waveA + waveB + radial) / 3; // -1 .. 1

        // Add a soft second radial for extra organic shape.
        const ripple = Math.sin(dist * 0.006 + t * 0.5) * 0.35;
        intensity = clamp(intensity + ripple, -1, 1);

        const normalized = mapRange(intensity, -1, 1, 0, 1);
        const charIndex = Math.floor(normalized * (CHARS.length - 1));
        const char = CHARS[charIndex];

        // Very low alpha preserves the minimalist feel.
        let baseAlpha = clamp(mapRange(normalized, 0, 1, MIN_ALPHA, MAX_ALPHA), MIN_ALPHA, MAX_ALPHA);

        let cursorInfluence = 0;
        if (mouseActive) {
          const cursorDx = x - mouseX;
          const cursorDy = y - mouseY;
          const cursorDistSq = cursorDx * cursorDx + cursorDy * cursorDy;
          if (cursorDistSq < radiusSq) {
            cursorInfluence = 1 - Math.sqrt(cursorDistSq) / CURSOR_RADIUS;
          }
        }

        ctx.globalAlpha = clamp(baseAlpha + cursorInfluence * CURSOR_ALPHA_BOOST, 0, 0.9);
        ctx.fillStyle = cursorInfluence > 0 ? CURSOR_COLOR : baseColor;
        ctx.fillText(char, x, y);
      }
    }

    ctx.globalAlpha = 1;
  }

  function tick(now) {
    if (!canvas || !ctx) return;
    if (isPaused) return;

    // Target ~20 fps for a calm, less CPU-heavy effect.
    if (now - lastFrame < 50) {
      rafId = requestAnimationFrame(tick);
      return;
    }
    lastFrame = now;

    draw();

    rafId = requestAnimationFrame(tick);
  }

  function start() {
    if (rafId) return;
    isPaused = false;
    rafId = requestAnimationFrame(tick);
  }

  function init() {
    canvas = document.getElementById('ascii-background');
    if (!canvas) {
      // Not on the home page; stop any leftover animation.
      cleanup();
      return;
    }

    // Prevent duplicate loops on the same canvas instance.
    if (canvas.dataset.initialized) {
      start();
      return;
    }
    canvas.dataset.initialized = 'true';

    ctx = canvas.getContext('2d');
    setupCanvas();

    if (reducedMotion) {
      draw();
      return;
    }

    start();
  }

  function onResize() {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      setupCanvas();
      if (reducedMotion) draw();
    }, 100);
  }

  // Re-read reduced motion preference if changed while the site is open.
  const motionMedia = window.matchMedia('(prefers-reduced-motion: reduce)');
  motionMedia.addEventListener('change', (e) => {
    reducedMotion = e.matches;
    if (reducedMotion) {
      cleanup();
      draw();
    } else if (canvas && !isPaused) {
      start();
    }
  });

  window.addEventListener('resize', onResize);
  window.addEventListener('pointermove', onPointerMove);
  window.addEventListener('pointerleave', onPointerLeave);

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      isPaused = true;
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    } else if (canvas && !reducedMotion) {
      start();
    }
  });

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-preparation', cleanup);

  init();
})();
</script>
