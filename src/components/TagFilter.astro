---
interface Props { tags: string[] }
const { tags } = Astro.props;
---

<style>
  .tag-btn {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 999px;
    border: 0.5px solid var(--color-border);
    background: transparent;
    color: var(--color-tertiary);
    cursor: pointer;
    transition: all 0.15s;
  }
  .tag-btn.active {
    background: var(--color-fg);
    color: var(--color-bg);
    border-color: var(--color-fg);
  }
</style>

<div class="flex gap-1.5 flex-wrap" id="tag-filter">
  <button class="tag-btn active" data-tag="all">all</button>
  {tags.map((tag) => <button class="tag-btn" data-tag={tag}>{tag}</button>)}
</div>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const rows = document.querySelectorAll<HTMLElement>('[data-post-tag]');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      rows.forEach((row) => {
        row.style.display = (tag === 'all' || row.dataset.postTag === tag) ? '' : 'none';
      });
    });
  });
</script>