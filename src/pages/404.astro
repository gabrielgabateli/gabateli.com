---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="404">
  <Nav />
  <main class="flex flex-col items-center justify-center pt-20 pb-32 text-center">
    <p class="font-mono text-[10px] text-quaternary mb-6 tracking-widest uppercase">error</p>
    <h1 class="text-[48px] sm:text-[72px] font-medium tracking-tighter text-fg leading-none mb-4">404</h1>
    <p class="text-[15px] text-tertiary mb-10">página não encontrada.</p>
    <a href="/" class="font-mono text-[12px] text-tertiary hover:text-fg transition-colors">
      voltar ao início →
    </a>
  </main>
</BaseLayout>