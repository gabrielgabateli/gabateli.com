---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PostList from '../components/PostList.astro';

function formatUptime(since: Date): string {
  const ms = Date.now() - since.getTime();
  const minutes = Math.floor(ms / 60000);
  const hours = Math.floor(minutes / 60);
  const days = Math.floor(hours / 24);

  if (days < 1) return `${hours}h`;
  if (days < 30) return `${days}d`;

  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo`;

  const years = Math.floor(months / 12);
  const remainingMonths = months % 12;
  return remainingMonths > 0 ? `${years}y ${remainingMonths}mo` : `${years}y`;
}

const firstDeploy = new Date('2025-06-01');
const buildDate = new Date().toISOString().slice(0, 10);
const uptimeString = formatUptime(firstDeploy);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<BaseLayout>
  <Nav />
  <main class="pb-20">
    <section class="pt-4 pb-14">
      <h1 class="text-[20px] font-medium tracking-tight mb-1">gabriel gabateli alves</h1>
      <p class="font-mono text-[12px] text-tertiary mb-6">são paulo, brazil</p>
      <p class="text-[15px] text-secondary leading-relaxed max-w-[420px]">
        computer engineering student <span class="text-fg">@ fiap</span>.<br>
      </p>
      <div class="flex items-center gap-4 mt-6">
        <a href="https://github.com/gabrielgabateli" target="_blank" rel="noopener"
           class="font-mono text-[12px] text-tertiary hover:text-fg transition-colors"
           aria-label="github">
          github ↗
        </a>
        <a href="https://linkedin.com/in/gabateli" target="_blank" rel="noopener"
           class="font-mono text-[12px] text-tertiary hover:text-fg transition-colors"
           aria-label="linkedin">
          linkedin ↗
        </a>
        <a href="mailto:gabateli16@gmail.com"
           class="font-mono text-[12px] text-tertiary hover:text-fg transition-colors"
           aria-label="email">
          email ↗
        </a>
      </div>
    </section>

    <div class="flex items-center justify-between mb-4">
      <h2 class="text-[13px] font-medium tracking-tight">writing</h2>
      <a href="/blog" class="font-mono text-[11px] text-quaternary hover:text-fg transition-colors">
        ver todos →
      </a>
    </div>
    <PostList posts={posts} />

    <footer class="mt-16 pt-6 border-t border-border">
      <p class="font-mono text-[11px] text-quaternary">
        gabriel gabateli · são paulo · {new Date().getFullYear()} · uptime: {uptimeString} · built: {buildDate}
      </p>
    </footer>
  </main>
</BaseLayout>
